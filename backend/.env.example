# =================================================
# GITHUB INTEGRATION
# =================================================
GITHUB_TOKEN=your_github_token_here
GITHUB_PAT=your_github_pat_here

# =================================================
# AI PROVIDERS & LLM CONFIG
# =================================================
LLM_PROVIDER=groq # 'groq' or 'gemini'
EMBEDDING_PROVIDER=local

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# OLLAMA CONFIG (Points to host machine Ollama)
OLLAMA_HOST=http://host.docker.internal:11434

# =================================================
# INFRASTRUCTURE CONNECTION URLS
# =================================================
DATABASE_URL=postgresql://postgres:12345@db/scopesense
REDIS_URL=redis://redis:6379/0

# =================================================
# FILESYSTEM & DIRECTORY SHARING
# =================================================
# Shared temp directory inside containers for async tasks to share uploads
TMPDIR=/app/data/uploads
